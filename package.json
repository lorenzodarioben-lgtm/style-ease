{
  "name": "style-ease",
  "version": "1.0.0",
  "private": true,
  "description": "A responsive front-end fashion storefront built with Vue, Vue Router, and Vite.",
  "type": "module",
  "homepage": "https://lorenzodarioben-lgtm.github.io/style-ease/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lorenzodarioben-lgtm/style-ease.git"
  },
  "bugs": {
    "url": "https://github.com/lorenzodarioben-lgtm/style-ease/issues"
  },
  "author": "Lorenzo Ben",
  "license": "MIT",
  "keywords": [
    "vue",
    "vite",
    "vue-router",
    "vitest",
    "eslint",
    "prettier",
    "github-actions",
    "github-pages",
    "storefront",
    "ecommerce",
    "responsive-design",
    "accessibility"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{css,html,js,json,md}\" .prettierrc",
    "format:check": "prettier --check \"**/*.{css,html,js,json,md}\" .prettierrc",
    "test": "vitest",
    "test:run": "vitest run",
    "validate": "run-s format:check lint test:run build"
  },
  "dependencies": {
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.9.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
